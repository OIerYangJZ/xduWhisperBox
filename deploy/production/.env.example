# =============================================================================
# XDU WhisperBox 生产环境配置模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# 必填：核心服务设置
# =============================================================================

BACKEND_ENV=production
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080
# 可选：统一认证回调对外固定域名/Origin。
# 当站点会被多个 Host 访问，或反代/端口与 IDS 已登记地址不一致时，务必设置为 IDS 已注册的 HTTPS 地址。
# 示例：BACKEND_XIDIAN_PUBLIC_ORIGIN=https://treehole.example.com
BACKEND_XIDIAN_PUBLIC_ORIGIN=

# 必填：管理员账号（生产环境必须修改默认密码）
BACKEND_ADMIN_USERNAME=admin
BACKEND_ADMIN_PASSWORD=<请替换为强密码，至少12位，包含大小写字母和数字>

# 必填：数据库配置（SQLite / postgresql / mysql）
BACKEND_DB_TYPE=sqlite
# SQLite 示例（本地文件）
BACKEND_DB_FILE=/opt/xdu-whisperbox/shared/backend/data/treehole.db
# PostgreSQL 示例（取消注释并填入实际值）
# BACKEND_DB_TYPE=postgresql
# BACKEND_DATABASE_URL=postgresql://user:pass@host:5432/xdu_treehole
# MySQL 示例（取消注释并填入实际值）
# BACKEND_DB_TYPE=mysql
# BACKEND_DATABASE_URL=mysql://user:pass@host:3306/xdu_treehole

# 必填：对象存储配置（local / s3 / oss）
BACKEND_OBJECT_STORAGE_BACKEND=s3
BACKEND_STORAGE_DIR=/opt/xdu-whisperbox/shared/backend/storage

# S3 兼容存储（如腾讯云COS、AWS S3、阿里云OSS等）
BACKEND_S3_BUCKET=xdu-treehole
BACKEND_S3_ENDPOINT=https://s3.cn-north-1.amazonaws.com.cn
BACKEND_S3_ACCESS_KEY_ID=<your-access-key>
BACKEND_S3_SECRET_ACCESS_KEY=<your-secret-key>
BACKEND_S3_REGION=cn-north-1

# 本地存储（仅开发/演示使用，生产不推荐）
# BACKEND_OBJECT_STORAGE_BACKEND=local
# BACKEND_STORAGE_DIR=/opt/xdu-whisperbox/shared/backend/storage

# Web 构建产物路径（Flutter build web 输出目录）
BACKEND_WEB_ROOT=/opt/xdu-whisperbox/current/build/web

# =============================================================================
# SMTP 邮件配置（用于用户注册验证码）
# =============================================================================

BACKEND_SMTP_HOST=smtp.qq.com
BACKEND_SMTP_PORT=465
BACKEND_SMTP_USERNAME=your@qq.com
BACKEND_SMTP_PASSWORD=<SMTP授权码>
BACKEND_SMTP_FROM_EMAIL=your@qq.com
BACKEND_SMTP_FROM_NAME=XDU Treehole
BACKEND_SMTP_USE_SSL=true
BACKEND_SMTP_USE_STARTTLS=false

# =============================================================================
# 安全配置（生产环境必须为 false）
# =============================================================================

BACKEND_ALLOW_DEBUG_VERIFY_CODE=false
BACKEND_INCLUDE_DEBUG_CODE=false

# =============================================================================
# 可选：数据迁移（首次从 SQLite 切换到 PostgreSQL/MySQL 时使用）
# =============================================================================

# BACKEND_MIGRATE_ON_STARTUP=false
# BACKEND_MIGRATION_SOURCE=sqlite

# =============================================================================
# 可选：运行参数
# =============================================================================

# BACKEND_LOG_LEVEL=INFO
# BACKEND_MAX_WORKERS=4

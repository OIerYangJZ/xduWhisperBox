# Core service settings
BACKEND_ADMIN_USERNAME=admin
BACKEND_ADMIN_PASSWORD=change-me-now
BACKEND_ENV=production
BACKEND_DB_FILE=/opt/xdu-whisperbox/shared/backend/data/treehole.db
BACKEND_STORAGE_DIR=/opt/xdu-whisperbox/shared/backend/storage/objects
BACKEND_OBJECT_STORAGE_BACKEND=local
# Set this to the IDS-registered public HTTPS origin when reverse proxy / IP access differs.
# Example: BACKEND_XIDIAN_PUBLIC_ORIGIN=https://treehole.example.com
BACKEND_XIDIAN_PUBLIC_ORIGIN=

# SMTP settings
BACKEND_SMTP_HOST=smtp.qq.com
BACKEND_SMTP_PORT=465
BACKEND_SMTP_USERNAME=your@qq.com
BACKEND_SMTP_PASSWORD=replace-with-smtp-auth-code
BACKEND_SMTP_FROM_EMAIL=your@qq.com
BACKEND_SMTP_FROM_NAME=XDU Treehole
BACKEND_SMTP_USE_SSL=true
BACKEND_SMTP_USE_STARTTLS=false

# Debug settings
# WARNING: MUST be false in production. When true, any verify code defaults to "123456".
BACKEND_ALLOW_DEBUG_VERIFY_CODE=false
# WARNING: MUST be false in production. When true, HTTP responses may include extra debug fields.
BACKEND_INCLUDE_DEBUG_CODE=false
